# Optional. Override the SQLite file location. Default: ./data/license-server.db
# LICENSE_DB_PATH=/var/lib/signportal/license.db

# Optional. PEM strings for the Ed25519 signing keypair. When unset,
# data/keys/ holds the keys; first run generates them. Production should
# set these from a secrets manager so secrets aren't on disk.
# LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Used by `npm run db:init` to seed the first admin without prompting.
# Optional — interactive prompt asks otherwise.
# ADMIN_EMAIL=admin@signportal.local
# ADMIN_PASSWORD=replace-with-a-long-passphrase
